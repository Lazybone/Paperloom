{
  "name": "@paperloom/optimizer",
  "version": "0.3.0",
  "description": "Client-side TypeScript port of b1rdmania/epubkit, targeted at the Paperloom 960x540 16-gray e-paper display. Bundles into docs/optimizer/.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs && node scripts/size-check.mjs && node scripts/copy-to-docs.mjs",
    "build:dev": "node scripts/build.mjs --dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "baseline": "node scripts/bundle-baseline.mjs",
    "fixtures": "node test/fixtures/build-fixtures.mjs"
  },
  "dependencies": {
    "fflate": "0.8.2",
    "css-tree": "3.1.0"
  },
  "devDependencies": {
    "@types/css-tree": "2.3.10",
    "@types/node": "20.14.10",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "@vitest/coverage-v8": "2.1.8",
    "esbuild": "0.24.0",
    "eslint": "8.57.1",
    "happy-dom": "15.11.7",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
