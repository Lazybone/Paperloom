# ─── PlatformIO ──────────────────────────────────────────────────────
.pio/
.pioenvs/
.piolibdeps/
build/
compile_commands.json

# ─── pioarduino / ESP-IDF custom-build artefacts ─────────────────────
# Created when pioarduino's custom_sdkconfig feature triggers a partial
# IDF rebuild (or when an aborted build leaves cache state behind).
# All regenerated on demand — never tracked.
.dummy/
managed_components/
dependencies.lock
sdkconfig
sdkconfig.defaults
sdkconfig.old
src/idf_component.yml
src/CMakeLists.txt

# ─── User-specific config (contains WiFi credentials) ───────────────
include/config.h
# Local maintainer scratch notes live under docs/; do NOT track them by
# default. Exception: docs/kosync.md is part of the shipped repo
# (linked from README.md) and is explicitly opted-in.
docs/*
!docs/kosync.md

# ─── Compiled binaries ───────────────────────────────────────────────
*.bin
*.elf
*.hex
*.map
*.o
*.a
# Exception: the merged firmware that ships next to the web flasher
# stays in git so GitHub Pages can serve it same-origin (CORS workaround,
# see tools/build.py + commit f4efee6).
!site/flasher/firmware/Paperloom-merged.bin

# ─── Splash-generator side outputs ───────────────────────────────────
tools/splash_screen.bmp
tools/splash_screen_preview.png

# ─── Font build cache (regenerable TTF cache for tools/fontconvert.py) ─
.font-cache/

# ─── Python ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ─── IDE settings ────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
.cache/

# ─── OS files ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# ─── Backups / temp / logs ───────────────────────────────────────────
*.bak
*.bak.*
*.orig
*.tmp
*.swp
*~
*.log

# ─── Claude Code ─────────────────────────────────────────────────────
.claude/
.codewright/
CLAUDE.md
